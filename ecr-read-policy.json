{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowPullFromLibraryReservationRepos",
            "Effect": "Allow",
            "Action": [
                "ecr:GetAuthorizationToken"
            ],
            "Resource": "*"
        },
        {
            "Sid": "AllowGetImageFromRepo",
            "Effect": "Allow",
            "Action": [
                "ecr:BatchGetImage",
                "ecr:GetDownloadUrlForLayer",
                "ecr:BatchCheckLayerAvailability"
            ],
            "Resource": "arn:aws:ecr:*:*:repository/bedrock-agentcore-*"
        }
    ]
}
